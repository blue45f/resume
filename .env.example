# ─────────────────────────────────────────────────────────────────────────
# 로컬 개발용 예시입니다. 운영(Cloud Run)에서는 비밀값을 이 파일이 아니라
# Secret Manager 에서 주입합니다. 배포·환경변수 전체는 docs/DEPLOYMENT.md 참조.
# 운영에서 필수: DATABASE_URL, JWT_SECRET, 그리고 LLM 키 1개 이상 (없으면 부팅 실패)
# ─────────────────────────────────────────────────────────────────────────

# Database (PostgreSQL - Neon 무료 티어 추천)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Server
# Cloud Run 은 PORT 를 주입합니다(보통 8080). 로컬 기본값은 3001.
PORT=3001
NODE_ENV=development

# URLs (운영 환경에 맞게 변경)
# 로컬: API_URL=http://localhost:3001 / FRONTEND_URL=http://localhost:5173
API_URL=https://your-api.onrender.com
FRONTEND_URL=https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,https://your-frontend.vercel.app

# JWT (프로덕션에서 반드시 변경!)
JWT_SECRET=your-secret-key-min-32-chars

# ─── OAuth 소셜 로그인 (선택) ───
# 각 프로바이더 콘솔에서 앱 생성 후 키 입력
# 콜백 URL 형식: {API_URL}/api/auth/{provider}/callback

# Google (https://console.cloud.google.com/apis/credentials)
# 기본 로그인은 GIS(Google Identity Services) ID-token flow 를 사용한다 — 백엔드는
# GOOGLE_CLIENT_ID 만 audience 로 사용해 ID 토큰을 검증하며 client secret 은 불필요하다.
# GIS 버튼을 쓰려면 콘솔의 OAuth client "승인된 JavaScript 원본"에 프론트 origin(예:
# http://localhost:5173, 운영 도메인)을 등록해야 한다(redirect URI 와 별개).
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET 은 GitHub/Kakao 와 동일한 (레거시) redirect 코드 flow 및 계정 연동
# 콜백(/api/auth/google/callback)에만 필요하다. GIS 로그인만 쓰면 비워둬도 된다.
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
# 프론트엔드 GIS 버튼용 — 위 GOOGLE_CLIENT_ID 와 동일한 값을 넣는다(빌드 타임 노출, public).
VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# GitHub (https://github.com/settings/developers)
# GITHUB_CLIENT_ID=Ov23lixxxxxx
# GITHUB_CLIENT_SECRET=xxxx

# Kakao (https://developers.kakao.com)
# KAKAO_CLIENT_ID=xxxx

# ─── LLM 프로바이더 (하나 이상 설정) ───
# 우선순위: Gemini(무료) > Groq(무료) > n8n > OpenAI Compatible > Anthropic(유료)

# Gemini (무료, 추천 — 기본 LLM 프로바이더)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# 모델 단위 장애 시 1회 재시도할 보조 모델 (선택)
# GEMINI_FALLBACK_MODEL=gemini-1.5-flash
# 요청 타임아웃(ms) / 최대 출력 토큰 (선택, 기본 60000 / 4096)
# GEMINI_TIMEOUT_MS=60000
# GEMINI_MAX_OUTPUT_TOKENS=4096

# Groq (무료)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (유료)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI Compatible (Ollama 등 로컬)
# OPENAI_COMPATIBLE_URL=http://localhost:11434/v1
# OPENAI_COMPATIBLE_KEY=
# OPENAI_COMPATIBLE_MODEL=llama3

# n8n Webhook
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/resume-transform

# 기본 LLM 프로바이더 (미지정시 자동 선택)
# LLM_DEFAULT_PROVIDER=gemini

# ─── Cloudinary (파일 첨부 저장, 무료 25GB) ───
# https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Frontend (Vite 환경변수) ───
VITE_API_URL=http://localhost:3001
# VITE_MSW=true  # MSW 목 서버 활성화 (개발용)
# VITE_TOSS_CLIENT_KEY=test_ck_xxxxx  # 결제 연동 (토스페이먼츠)

# SurveyDesk 피드백 위젯 엔드포인트(미설정 시 위젯 비활성)
VITE_SURVEYDESK_URL=""

# ChangelogDesk 인앱 체인지로그 위젯 엔드포인트(미설정 시 비활성). PK 미지정 시 pk_demo.
VITE_CHANGELOGDESK_URL=""
# VITE_CHANGELOGDESK_PK="pk_demo"

# NotifyDesk 알림 벨 위젯 엔드포인트(미설정 시 비활성, 로그인 사용자만 렌더). PK 미지정 시 pk_demo.
VITE_NOTIFYDESK_URL=""
# VITE_NOTIFYDESK_PK="pk_demo"

# SearchDesk ⌘K 검색 팔레트 엔드포인트(미설정 시 비활성). PK 미지정 시 pk_demo.
VITE_SEARCHDESK_URL=""
# VITE_SEARCHDESK_PK="pk_demo"
