{
  "name": "@resume/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "이력서공방 프론트엔드 (Vite + React 19)",
  "scripts": {
    "dev": "cd ../.. && pnpm dev:client",
    "build": "cd ../.. && pnpm build:client",
    "lint": "cd ../.. && pnpm exec eslint packages/client",
    "typecheck": "cd ../.. && pnpm exec tsc -p packages/client/tsconfig.json --noEmit",
    "preview": "cd ../.. && pnpm preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@heejun/deskcloud": "^0.1.0",
    "@resume/shared": "workspace:*",
    "date-fns": "^4.4.0",
    "firebase": "^12.15.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/react-vite": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "storybook": "^10.4.6"
  }
}
