{
  "name": "@resume/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "이력서공방 프론트엔드 (Vite + React 19)",
  "scripts": {
    "dev": "cd ../.. && pnpm dev:client",
    "build": "cd ../.. && pnpm build:client",
    "lint": "cd ../.. && pnpm exec eslint packages/client",
    "typecheck": "cd ../.. && pnpm exec tsc -p packages/client/tsconfig.json --noEmit",
    "preview": "cd ../.. && pnpm preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@resume/shared": "workspace:*"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.7",
    "storybook": "^10.4.1"
  }
}
