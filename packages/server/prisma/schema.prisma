generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                     @id @default(uuid())
  email                   String                     @unique
  name                    String                     @default("")
  username                String                     @default("") // @username (프로필 URL)
  avatar                  String                     @default("")
  provider                String                     @default("") // google, github, kakao
  providerId              String                     @default("") @map("provider_id")
  passwordHash            String?                    @map("password_hash")
  role                    String                     @default("user") // user, admin
  userType                String                     @default("personal") @map("user_type") // personal, recruiter, company, coach
  companyName             String?                    @map("company_name")
  companyTitle            String?                    @map("company_title") // 직함
  plan                    String                     @default("free") // free, pro, enterprise
  planExpiresAt           DateTime?                  @map("plan_expires_at")
  isSample                Boolean                    @default(false) @map("is_sample")
  isOpenToWork            Boolean                    @default(false) @map("is_open_to_work") // 구직 중 상태 공개
  openToWorkRoles         String                     @default("") @map("open_to_work_roles") // 희망 직무 (콤마 구분)
  /// 사용자 선호 언어 (UI 표시 + i18n 통계). 빈 문자열 = 미설정 (browser 기본 사용)
  preferredLocale         String                     @default("") @map("preferred_locale")
  marketingOptIn          Boolean                    @default(false) @map("marketing_opt_in") // PIPA: 마케팅 수신 동의
  llmOptIn                Boolean                    @default(false) @map("llm_opt_in") // PIPA: 국외 LLM 이전 동의
  isSuspended             Boolean                    @default(false) @map("is_suspended") // 관리자에 의한 계정 정지
  createdAt               DateTime                   @default(now()) @map("created_at")
  resumes                 Resume[]
  applications            JobApplication[]
  comments                Comment[]
  applicationComments     ApplicationComment[]
  bookmarks               Bookmark[]
  notifications           Notification[]
  usageLogs               UsageLog[]
  followers               Follow[]                   @relation("Following")
  following               Follow[]                   @relation("Followers")
  sentScouts              ScoutMessage[]             @relation("SentScouts")
  receivedScouts          ScoutMessage[]             @relation("ReceivedScouts")
  sentMessages            DirectMessage[]            @relation("SentMessages")
  receivedMessages        DirectMessage[]            @relation("ReceivedMessages")
  coverLetters            CoverLetter[]
  jobPosts                JobPost[]
  communityPosts          CommunityPost[]
  skillEndorsements       SkillEndorsement[]
  authoredNotices         Notice[]
  noticeComments          NoticeComment[]
  noticeHistoryEdits      NoticeHistory[]
  curatedJobs             CuratedJob[]
  drafts                  Draft[]
  interviewAnswers        InterviewAnswer[]
  communityLikes          CommunityLike[]
  tags                    Tag[]
  templates               Template[]
  forbiddenWords          ForbiddenWord[]
  ownedStudyGroups        StudyGroup[]               @relation("GroupOwner")
  studyGroupMemberships   StudyGroupMember[]         @relation("GroupMember")
  studyGroupQuestions     StudyGroupQuestion[]       @relation("GroupQuestion")
  studyGroupPosts         StudyGroupPost[]           @relation("GroupPost")
  studyGroupPostComments  StudyGroupPostComment[]    @relation("GroupPostComment")
  studyGroupPostReactions StudyGroupPostReaction[]   @relation("GroupPostReaction")
  resumeReports           ResumeReport[]             @relation("ResumeReporter")
  communityPostReports    CommunityPostReport[]      @relation("CommunityPostReporter")
  studyGroupEvents        StudyGroupEvent[]          @relation("GroupEventAuthor")
  studyGroupEventRsvps    StudyGroupEventRsvp[]      @relation("GroupEventRsvp")
  coachProfile            CoachProfile?
  coachingSessions        CoachingSession[]          @relation("CoachingClient")
  authoredJobQuestions    JobInterviewQuestion[]     @relation("JobQuestionAuthor")
  jobQuestionVotes        JobInterviewQuestionVote[] @relation("JobQuestionVoter")
  grantedResumeAccess     ResumeViewer[]             @relation("ResumeViewerGranter")
  receivedResumeAccess    ResumeViewer[]             @relation("ResumeViewerRecipient")
  hostedCoffeeChats       CoffeeChat[]               @relation("CoffeeChatHost")
  requestedCoffeeChats    CoffeeChat[]               @relation("CoffeeChatRequester")
  sentWebrtcSignals       WebrtcSignal[]             @relation("WebrtcSignalFrom")
  receivedWebrtcSignals   WebrtcSignal[]             @relation("WebrtcSignalTo")

  @@unique([provider, providerId])
  @@map("users")
}

model Resume {
  id          String   @id @default(uuid())
  title       String   @default("")
  slug        String   @default("")
  viewCount   Int      @default(0) @map("view_count") // 공개 조회수
  visibility  String   @default("private")
  isSample    Boolean  @default(false) @map("is_sample")
  /// 신고 누적 건수 — 임계치 도달 시 autoHidden=true 로 전환
  reportCount Int      @default(0) @map("report_count")
  /// 신고 누적으로 자동 숨김된 상태 (admin 이 override 가능)
  autoHidden  Boolean  @default(false) @map("auto_hidden")
  userId      String?  @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user              User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalInfo      PersonalInfo?
  experiences       Experience[]
  educations        Education[]
  skills            Skill[]
  projects          Project[]
  certifications    Certification[]
  languages         Language[]
  awards            Award[]
  activities        Activity[]
  attachments       Attachment[]
  tags              TagsOnResumes[]
  versions          ResumeVersion[]
  shareLinks        ShareLink[]
  transformations   LlmTransformation[]
  applications      JobApplication[]
  comments          Comment[]
  bookmarks         Bookmark[]
  scoutMessages     ScoutMessage[]
  coverLetters      CoverLetter[]
  skillEndorsements SkillEndorsement[]
  reports           ResumeReport[]
  allowedViewers    ResumeViewer[]

  @@index([userId])
  @@index([visibility])
  @@map("resumes")
}

/// 선택 공개(visibility="selective") 시 열람 가능한 사용자 화이트리스트.
/// 소유자가 추가/제거하며, 추가 즉시 viewer 가 열람 가능.
/// 확장 필드: expiresAt(만료 자동 제거), message(소유자 메모), addedBy(누가 추가)
model ResumeViewer {
  id           String    @id @default(uuid())
  resumeId     String    @map("resume_id")
  userId       String    @map("user_id")
  addedById    String?   @map("added_by_id")
  message      String?   @db.Text
  expiresAt    DateTime? @map("expires_at")
  lastViewedAt DateTime? @map("last_viewed_at")
  viewCount    Int       @default(0) @map("view_count")
  createdAt    DateTime  @default(now()) @map("created_at")

  resume  Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user    User   @relation("ResumeViewerRecipient", fields: [userId], references: [id], onDelete: Cascade)
  addedBy User?  @relation("ResumeViewerGranter", fields: [addedById], references: [id], onDelete: SetNull)

  @@unique([resumeId, userId])
  @@index([userId])
  @@index([resumeId])
  @@index([expiresAt])
  @@map("resume_viewers")
}

/// 커피챗 — 가벼운 1:1 만남 신청. 코치/리쿠르터/시니어 등에게 30분 정도 대화 요청.
/// 수락 시 WebRTC 음성/화상 통화 가능 (서버는 signaling 만, 미디어는 P2P).
model CoffeeChat {
  id          String    @id @default(uuid())
  hostId      String    @map("host_id")
  requesterId String    @map("requester_id")
  /// pending | accepted | rejected | completed | cancelled
  status      String    @default("pending")
  scheduledAt DateTime? @map("scheduled_at")
  durationMin Int       @default(30) @map("duration_min")
  topic       String    @default("")
  message     String    @default("") @db.Text
  /// voice | video | chat
  modality    String    @default("video")
  /// WebRTC room ID — accepted 시 자동 발급
  roomId      String?   @map("room_id")
  hostNote    String    @default("") @db.Text @map("host_note")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  host      User @relation("CoffeeChatHost", fields: [hostId], references: [id], onDelete: Cascade)
  requester User @relation("CoffeeChatRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([hostId, status])
  @@index([requesterId, status])
  @@index([roomId])
  @@map("coffee_chats")
}

/// WebRTC 시그널링 메시지 — offer/answer/ICE candidate 임시 큐.
/// 30초 후 자동 정리 (cron). 서버는 메시지 전달만 — 미디어는 client-to-client.
model WebrtcSignal {
  id         String   @id @default(uuid())
  roomId     String   @map("room_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  /// offer | answer | ice | bye
  type       String
  payload    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser User @relation("WebrtcSignalFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("WebrtcSignalTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, roomId, createdAt])
  @@map("webrtc_signals")
}

/// 채용공고 URL 파싱 결과 캐시 — 동일 URL 재요청 시 외부 fetch + LLM 호출 절감.
/// TTL: 24시간 (서비스에서 createdAt 비교로 만료 판정).
model JobUrlCache {
  url       String   @id @db.Text
  data      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("job_url_cache")
}

/// 공개 이력서에 대한 사용자 신고 — (resumeId, reporterId) unique 로 중복 방지
model ResumeReport {
  id         String   @id @default(uuid())
  resumeId   String   @map("resume_id")
  reporterId String   @map("reporter_id")
  /// spam | inappropriate | fake | copyright | other
  reason     String   @default("other")
  detail     String   @default("") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  reporter User   @relation("ResumeReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([resumeId, reporterId])
  @@index([resumeId])
  @@map("resume_reports")
}

model PersonalInfo {
  id        String @id @default(uuid())
  resumeId  String @unique @map("resume_id")
  name      String @default("")
  email     String @default("")
  phone     String @default("")
  address   String @default("")
  website   String @default("")
  github    String @default("") // GitHub URL
  summary   String @default("")
  photo     String @default("") // 증명사진 URL 또는 base64
  birthYear String @default("") @map("birth_year")
  links     String @default("")
  military  String @default("")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("personal_info")
}

model Experience {
  id           String  @id @default(uuid())
  resumeId     String  @map("resume_id")
  company      String  @default("")
  position     String  @default("")
  department   String  @default("") // 부서/팀
  startDate    String  @default("") @map("start_date")
  endDate      String  @default("") @map("end_date")
  current      Boolean @default(false)
  description  String  @default("")
  achievements String  @default("") // 주요 성과 (하이라이트)
  techStack    String  @default("") @map("tech_stack") // 사용 기술 (예: React, TypeScript, AWS)
  sortOrder    Int     @default(0) @map("sort_order")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("experiences")
}

model Education {
  id          String @id @default(uuid())
  resumeId    String @map("resume_id")
  school      String @default("")
  degree      String @default("")
  field       String @default("")
  gpa         String @default("") // 학점 (예: 3.4/4.5)
  startDate   String @default("") @map("start_date")
  endDate     String @default("") @map("end_date")
  description String @default("")
  sortOrder   Int    @default(0) @map("sort_order")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("educations")
}

model Skill {
  id        String @id @default(uuid())
  resumeId  String @map("resume_id")
  category  String @default("")
  items     String @default("")
  sortOrder Int    @default(0) @map("sort_order")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("skills")
}

model Project {
  id          String @id @default(uuid())
  resumeId    String @map("resume_id")
  name        String @default("")
  company     String @default("") // 소속 회사
  role        String @default("")
  startDate   String @default("") @map("start_date")
  endDate     String @default("") @map("end_date")
  description String @default("")
  techStack   String @default("") @map("tech_stack") // 사용 기술
  link        String @default("")
  sortOrder   Int    @default(0) @map("sort_order")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("projects")
}

model Certification {
  id           String @id @default(uuid())
  resumeId     String @map("resume_id")
  name         String @default("")
  issuer       String @default("") // 발급기관
  issueDate    String @default("") @map("issue_date")
  expiryDate   String @default("") @map("expiry_date")
  credentialId String @default("") @map("credential_id") // 자격번호
  description  String @default("")
  sortOrder    Int    @default(0) @map("sort_order")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("certifications")
}

model Language {
  id        String @id @default(uuid())
  resumeId  String @map("resume_id")
  name      String @default("") // 언어명 (영어, 일본어 등)
  testName  String @default("") @map("test_name") // 시험명 (TOEIC, JLPT 등)
  score     String @default("") // 점수/등급
  testDate  String @default("") @map("test_date")
  sortOrder Int    @default(0) @map("sort_order")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("languages")
}

model Award {
  id          String @id @default(uuid())
  resumeId    String @map("resume_id")
  name        String @default("") // 수상명
  issuer      String @default("") // 수여기관
  awardDate   String @default("") @map("award_date")
  description String @default("")
  sortOrder   Int    @default(0) @map("sort_order")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("awards")
}

model Activity {
  id           String @id @default(uuid())
  resumeId     String @map("resume_id")
  name         String @default("") // 활동명
  organization String @default("") // 기관/단체
  role         String @default("") // 역할
  startDate    String @default("") @map("start_date")
  endDate      String @default("") @map("end_date")
  description  String @default("")
  sortOrder    Int    @default(0) @map("sort_order")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("activities")
}

model Attachment {
  id           String   @id @default(uuid())
  resumeId     String   @map("resume_id")
  filename     String // 저장된 파일명 (UUID)
  originalName String   @map("original_name") // 원본 파일명
  mimeType     String   @map("mime_type")
  size         Int // bytes
  data         String? // base64 인코딩된 파일 데이터 (DB 저장 모드)
  category     String   @default("document") // certificate, portfolio, document, reference
  description  String   @default("")
  createdAt    DateTime @default(now()) @map("created_at")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("attachments")
}

model Tag {
  id      String          @id @default(uuid())
  name    String          @unique
  color   String          @default("#6366f1")
  userId  String?         @map("user_id") // 생성자 (null = 시스템/시드)
  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  resumes TagsOnResumes[]

  @@map("tags")
}

model TagsOnResumes {
  resumeId String @map("resume_id")
  tagId    String @map("tag_id")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resumeId, tagId])
  @@map("tags_on_resumes")
}

model ResumeVersion {
  id            String   @id @default(uuid())
  resumeId      String   @map("resume_id")
  versionNumber Int      @map("version_number")
  snapshot      String // JSON snapshot of full resume data
  description   String   @default("")
  createdAt     DateTime @default(now()) @map("created_at")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, versionNumber])
  @@index([resumeId])
  @@map("resume_versions")
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  category    String   @default("general")
  userId      String?  @map("user_id") // 생성자 (null = 시스템 기본 템플릿)
  prompt      String   @default("") // LLM prompt template content
  layout      String   @default("{}") // JSON: section order, visibility, style config for local transform
  visibility  String   @default("private") // private, public
  usageCount  Int      @default(0) @map("usage_count")
  rating      Float?   @default(0)
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("templates")
}

model ShareLink {
  id           String    @id @default(uuid())
  resumeId     String    @map("resume_id")
  token        String    @unique
  passwordHash String?   @map("password_hash")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@index([token])
  @@index([expiresAt])
  @@map("share_links")
}

model LlmTransformation {
  id             String   @id @default(uuid())
  resumeId       String   @map("resume_id")
  templateType   String   @map("template_type")
  targetLanguage String   @default("ko") @map("target_language")
  jobDescription String?  @map("job_description")
  result         String // JSON transformation result
  tokensUsed     Int      @default(0) @map("tokens_used")
  model          String   @default("unknown")
  createdAt      DateTime @default(now()) @map("created_at")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@index([createdAt])
  @@map("llm_transformations")
}

model JobApplication {
  id          String   @id @default(uuid())
  userId      String?
  resumeId    String?
  company     String
  position    String
  url         String?
  status      String   @default("applied") // applied, screening, interview, offer, rejected, withdrawn
  appliedDate String?
  notes       String?
  salary      String?
  location    String?
  visibility  String   @default("private") // private, public
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user                User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume              Resume?              @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  applicationComments ApplicationComment[]
  coverLetters        CoverLetter[]

  @@index([userId])
  @@index([status])
}

model Comment {
  id         String   @id @default(uuid())
  resumeId   String
  userId     String?
  authorName String
  content    String
  parentId   String?  @map("parent_id")
  createdAt  DateTime @default(now())

  resume  Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user    User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([resumeId])
  @@index([parentId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  resumeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([userId, resumeId])
  @@index([userId])
  @@map("bookmarks")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String // comment, bookmark, application_comment
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model UsageLog {
  id        String   @id @default(uuid())
  userId    String
  feature   String // ai_transform, cover_letter, translation, ai_coaching
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature, createdAt])
  @@map("usage_logs")
}

model ApplicationComment {
  id            String   @id @default(uuid())
  applicationId String
  userId        String?
  authorName    String
  content       String
  createdAt     DateTime @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([applicationId])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model ScoutMessage {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  resumeId   String?  @map("resume_id")
  company    String   @default("")
  position   String   @default("")
  message    String
  read       Boolean  @default(false)
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User    @relation("SentScouts", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User    @relation("ReceivedScouts", fields: [receiverId], references: [id], onDelete: Cascade)
