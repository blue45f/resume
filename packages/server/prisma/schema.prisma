/// 스터디 그룹의 카페형 게시판 — 멤버가 자유롭게 글·자료·공지 공유
model StudyGroupPost {
  id           String   @id @default(uuid())
  groupId      String   @map("group_id")
  userId       String   @map("user_id")
  title        String
  content      String   @db.Text
  /// category: notice(공지), free(자유), question(질문), resource(자료공유), study-log(학습일지)
  category     String   @default("free")
  /// 첨부파일 JSON 배열 [{ url, name, size, type }]
  attachments  Json     @default("[]")
  isPinned     Boolean  @default(false) @map("is_pinned")
  viewCount    Int      @default(0) @map("view_count")
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  /// 태그 JSON 배열 ["react","cs","interview"] — 검색/필터용
  tags Json @default("[]")

  group     StudyGroup               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User                     @relation("GroupPost", fields: [userId], references: [id], onDelete: Cascade)
  comments  StudyGroupPostComment[]
  reactions StudyGroupPostReaction[]

  @@index([groupId, createdAt])
  @@index([userId])
  @@index([category])
  @@map("study_group_posts")
}

/// 스터디 게시물 이모지 리액션 — 유저당 각 이모지 1회 토글
model StudyGroupPostReaction {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  /// 👍 ❤️ 🔥 👏 🎉 🤔 중 하나 (서버에서 화이트리스트 검증)
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  post StudyGroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User           @relation("GroupPostReaction", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@index([postId])
  @@index([userId])
  @@map("study_group_post_reactions")
}

/// 스터디 그룹 게시글 댓글 — parentId 로 1단계 답글(대댓글) 지원
model StudyGroupPostComment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  parentId  String?  @map("parent_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post    StudyGroupPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User                    @relation("GroupPostComment", fields: [userId], references: [id], onDelete: Cascade)
  parent  StudyGroupPostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies StudyGroupPostComment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@index([userId])
  @@index([parentId])
  @@map("study_group_post_comments")
}

/// 스터디 그룹 일정 — 화상 스터디/오프라인 모임/과제 마감 등
model StudyGroupEvent {
  id          String    @id @default(uuid())
  groupId     String    @map("group_id")
  authorId    String    @map("author_id")
  title       String
  description String    @default("") @db.Text
  /// online | offline | assignment | deadline
  kind        String    @default("online")
  location    String    @default("")
  /// 화상회의 링크 (Zoom/Meet 등)
  meetingUrl  String    @default("") @map("meeting_url")
  startsAt    DateTime  @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  group  StudyGroup            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author User                  @relation("GroupEventAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  rsvps  StudyGroupEventRsvp[]

  @@index([groupId, startsAt])
  @@map("study_group_events")
}

/// 일정 참석 응답 (going/maybe/declined)
model StudyGroupEventRsvp {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  /// going | maybe | declined
  status    String   @default("going")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event StudyGroupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User            @relation("GroupEventRsvp", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("study_group_event_rsvps")
}

model JobInterviewQuestion {
  id           String   @id @default(uuid())
  jobPostId    String?  @map("job_post_id")
  curatedJobId String?  @map("curated_job_id")
  companyName  String   @map("company_name")
  position     String
  question     String   @db.Text
  sampleAnswer String   @default("") @map("sample_answer") @db.Text
  category     String   @default("")
  difficulty   String   @default("intermediate")
  source       String   @default("user")
  authorId     String?  @map("author_id")
  upvotes      Int      @default(0)
  isApproved   Boolean  @default(false) @map("is_approved") // 관리자 채택 여부
  isRejected   Boolean  @default(false) @map("is_rejected") // 관리자 반려 여부
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  jobPost    JobPost?                   @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  curatedJob CuratedJob?                @relation(fields: [curatedJobId], references: [id], onDelete: Cascade)
  author     User?                      @relation("JobQuestionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  votes      JobInterviewQuestionVote[]

  @@index([jobPostId])
  @@index([curatedJobId])
  @@index([companyName, position])
  @@map("job_interview_questions")
}

model JobInterviewQuestionVote {
  id         String   @id @default(uuid())
  questionId String   @map("question_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  question JobInterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User                 @relation("JobQuestionVoter", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
  @@index([userId])
  @@map("job_interview_question_votes")
}
