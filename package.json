{
  "name": "resume-platform",
  "private": true,
  "version": "2.1.0",
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"nest start --watch -b swc\"",
    "dev:client": "vite",
    "dev:mock": "VITE_MSW=true vite",
    "dev:server": "nest start --watch -b swc",
    "build": "vite build && nest build",
    "build:client": "vite build",
    "build:client:dev": "vite build --mode development",
    "build:client:prod": "vite build --mode production",
    "build:server": "nest build",
    "start:server": "node dist-server/main.js",
    "deploy:gcp": "gcloud run deploy resume-api --source . --region asia-northeast3 --allow-unauthenticated --set-env-vars NODE_ENV=production",
    "lint": "eslint .",
    "format": "prettier --write \"server/**/*.ts\" \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"server/**/*.ts\" \"src/**/*.{ts,tsx}\"",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "jest --config jest-unit.config.js",
    "test:unit": "jest --config jest-unit.config.js",
    "test:unit:cov": "jest --config jest-unit.config.js --coverage",
    "test:e2e": "jest --config jest-e2e.config.js",
    "prisma:push": "prisma db push",
    "prisma:reset": "prisma migrate reset",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@hookform/resolvers": "^5.2.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tiptap/extension-character-count": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/sanitize-html": "^2.16.1",
    "@use-gesture/react": "^10.3.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.20",
    "docx": "^9.6.1",
    "dompurify": "^3.4.0",
    "dotenv": "^17.4.2",
    "helmet": "^8.1.0",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.3",
    "react-router-dom": "^7.14.1",
    "react-to-print": "^3.3.0",
    "recharts": "^2.15.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.3",
    "sonner": "^2.0.7",
    "swiper": "^12.1.3",
    "tiptap": "^1.32.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.26",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.4",
    "prettier": "^3.8.3",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
