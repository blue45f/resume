{
  "name": "resume-platform",
  "private": true,
  "version": "2.1.0",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.0.0"
  },
  "prettier": "@heejun/prettier-config",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:client": "cd packages/client && vite",
    "dev:mock": "cd packages/client && VITE_MSW=true vite",
    "dev:server": "cd packages/server && nest start --watch -b swc",
    "build": "pnpm prisma:generate && pnpm build:client && pnpm build:server",
    "build:client": "cd packages/client && vite build",
    "build:client:dev": "cd packages/client && vite build --mode development",
    "build:client:prod": "cd packages/client && vite build --mode production",
    "build:server": "cd packages/server && nest build",
    "start:server": "node packages/server/dist/main.js",
    "start": "node packages/server/dist/main.js",
    "ci": "pnpm run lint:ci && pnpm run typecheck && pnpm run test && pnpm run test:client && pnpm run build && pnpm run format:check",
    "verify": "pnpm run validate:architecture && pnpm run ci",
    "verify:push": "pnpm run verify",
    "sonar": "sonar-scanner",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:ci": "pnpm run lint:strict",
    "sonar:ci": "sonar-scanner -Dsonar.qualitygate.wait=true",
    "deploy:gcp": "bash scripts/deploy-gcp.sh",
    "deploy:gcp:dry": "DRY_RUN=1 bash scripts/deploy-gcp.sh",
    "lint": "eslint .",
    "format": "prettier --write \"packages/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx}\"",
    "clean": "pnpm -r --if-present run clean",
    "preview": "cd packages/client && vite preview",
    "prisma:generate": "cd packages/server && prisma generate",
    "prisma:migrate": "cd packages/server && prisma migrate dev",
    "prisma:studio": "cd packages/server && prisma studio",
    "prisma:seed": "cd packages/server && tsx prisma/seed.ts",
    "test": "cd packages/server && jest --config jest-unit.config.js",
    "test:unit": "cd packages/server && jest --config jest-unit.config.js",
    "test:unit:cov": "cd packages/server && jest --config jest-unit.config.js --coverage",
    "test:e2e": "cd packages/server && jest --config jest-e2e.config.js",
    "test:client": "cd packages/client && vitest run",
    "test:client:watch": "cd packages/client && vitest",
    "prisma:push": "cd packages/server && prisma db push",
    "prisma:reset": "cd packages/server && prisma migrate reset",
    "typecheck": "pnpm prisma:generate && tsc -b --noEmit",
    "prepare": "husky || true",
    "validate:architecture": "node scripts/validate-architecture.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@hookform/resolvers": "^5.4.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@resume/shared": "workspace:*",
    "@sentry/nestjs": "^10.55.0",
    "@sentry/react": "^10.55.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tiptap/extension-character-count": "^3.26.0",
    "@tiptap/extension-link": "^3.24.0",
    "@tiptap/extension-placeholder": "^3.24.0",
    "@tiptap/pm": "^3.24.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@types/sanitize-html": "^2.16.1",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "2.0.2",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "docx": "^9.7.1",
    "dompurify": "^3.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "google-auth-library": "^10.7.0",
    "heic2any": "0.0.4",
    "helmet": "^8.2.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "ky": "^2.0.2",
    "mammoth": "1.12.0",
    "multer": "^2.1.1",
    "nestjs-zod": "^5.4.0",
    "pdf-parse": "2.4.5",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.78.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.17.0",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.4",
    "sonner": "^2.0.7",
    "swiper": "^12.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@heejun/eslint-config": "^5.0.0",
    "@heejun/prettier-config": "^3.0.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.8",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
