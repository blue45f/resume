{
  "name": "resume-platform",
  "private": true,
  "version": "2.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"nest start --watch -b swc\"",
    "dev:client": "vite",
    "dev:mock": "VITE_MSW=true vite",
    "dev:server": "nest start --watch -b swc",
    "build": "vite build && nest build",
    "build:client": "vite build",
    "build:server": "nest build",
    "start:server": "node dist-server/main.js",
    "lint": "eslint .",
    "format": "prettier --write \"server/**/*.ts\" \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"server/**/*.ts\" \"src/**/*.{ts,tsx}\"",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "jest --config jest-unit.config.js",
    "test:unit": "jest --config jest-unit.config.js",
    "test:unit:cov": "jest --config jest-unit.config.js --coverage",
    "test:e2e": "jest --config jest-e2e.config.js",
    "prisma:push": "prisma db push",
    "prisma:reset": "prisma migrate reset",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.9.0",
    "@tiptap/extension-character-count": "^3.22.1",
    "@tiptap/extension-link": "^3.22.0",
    "@tiptap/extension-placeholder": "^3.22.0",
    "@tiptap/pm": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@types/sanitize-html": "^2.16.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "docx": "^9.6.1",
    "dompurify": "^3.3.3",
    "helmet": "^8.1.0",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.3",
    "react-router-dom": "^7.13.2",
    "react-to-print": "^3.3.0",
    "recharts": "^2.15.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.2",
    "tiptap": "^1.32.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "msw": "^2.12.14",
    "prettier": "^3.8.1",
    "prisma": "^6.9.0",
    "supertest": "^7.1.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
