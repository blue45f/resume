{
  "compilerOptions": {
    "target": "ES2023",
    "module": "commonjs",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist-server/tsconfig.test.tsbuildinfo",
    "baseUrl": "./",
    "paths": {},
    "types": ["jest", "node"]
  },
  "include": ["test/**/*", "server/**/*.spec.ts", "server/**/*.test.ts"]
}
